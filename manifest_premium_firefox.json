{
    "manifest_version": 3,
    "name": "AI Privacy Shield - Premium",
    "version": "1.5.0",
    "description": "FULL AI surveillance protection. Block 37+ trackers including keystroke logging, session recording, and telemetry from Claude, ChatGPT, Gemini, Grok, Meta AI and more.",
    "browser_specific_settings": {
        "gecko": {
            "id": "ai-privacy-shield-premium@reflexionsoftware.com",
            "strict_min_version": "109.0"
        }
    },
    "permissions": [
        "cookies",
        "declarativeNetRequest",
        "declarativeNetRequestFeedback",
        "declarativeNetRequestWithHostAccess",
        "privacy",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ],
    "background": {
        "scripts": ["background.js"]
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
